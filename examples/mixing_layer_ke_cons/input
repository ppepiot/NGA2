# Parallelization
Partition : 8 1 1

# Mesh definition
Lx : 50
Ly : 50
Lz : 50
nx : 256
ny : 256
nz : 1

# EOS parameters: rho(Z)=rho0*rho1/((1-Z)*rho1+Z*rho0)
rho0 : 1
rho1 : 1
rhost: 3
Zst  : 0.2

# Disturbance amplitude
Wave amplitude : 0.01

# Fluid properties
Dynamic viscosity :   1e-2
Dynamic diffusivity : 1e-2

# Time integration
Max timestep size : 1e-1
Max cfl number :    0.8
Subiterations :     3

# Pressure solver
Pressure tolerance : 1e-6
Pressure iteration : 100

# Ensight output
Ensight output period : 2
