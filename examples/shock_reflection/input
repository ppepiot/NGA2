# Parallelization
Partition : 8 1 1

# Mesh definition
Lx : 4
Ly : 0.25
Lz : 1
nx : 512
ny : 32
nz : 1
Y sponge : 0.75

# Shock definition
Shock Mach :       10
Shock angle :      0
Shock thickness :  5e-3
Shock position :   2!0.1667

# Fluid properties
Gamma : 1.4

# Do we use SGS modeling
Use SGS model : .true.

# Time integration
Max timestep size : 2.5e-3
Max cfl number :    0.9
Subiterations :     50

# Pressure solver
Pressure tolerance : 1e-6
Pressure iteration : 100

# Ensight output
Ensight output period : 1e-2
