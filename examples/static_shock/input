# Parallelization
Partition : 1 1 1

# Mesh definition
Lx : 10
nx : 256

# Flow parameters
Gamma : 1.4
Mach :  10
Re :    1

# Do we use SGS modeling
Use SGS model : .true.

# Time integration
Max timestep size : 1e-2
Max cfl number :    0.9
Max time :          2
Subiterations :     50
Relaxation coeff:   0.6

# Pressure solver
Pressure tolerance : 1e-6
Pressure iteration : 100

# Ensight output
Ensight output period : 1e-2
