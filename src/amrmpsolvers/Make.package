# AMR multiphase solvers
f90EXE_sources += amrvof_class.f90 amrvof_geometry.f90 amrmpcomp_class.f90 amrmpincomp_class.f90

# PLICnet for interface normal reconstruction (from two_phase)
f90EXE_sources += plicnet.f90

INCLUDE_LOCATIONS += $(NGA_HOME)/src/amrmpsolvers
VPATH_LOCATIONS   += $(NGA_HOME)/src/amrmpsolvers
INCLUDE_LOCATIONS += $(NGA_HOME)/src/two_phase
VPATH_LOCATIONS   += $(NGA_HOME)/src/two_phase
